# baseURI: https://ontology.setu.nl/shapes#
# imports: https://ontology.setu.nl#
# prefix: setu

@prefix dc: <http://purl.org/dc/terms/> .
@prefix hropen: <https://hropenstandards.org/schema/xml/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix setu: <https://ontology.setu.nl#> .
@prefix setush: <https://ontology.setu.nl/shapes#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix sth: <https://ns.semantic-treehouse.nl/metadata/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://ontology.setu.nl/shapes#>
  rdf:type owl:Ontology ;
  owl:imports setu: ;
  dc:contributor <https://www.linkedin.com/in/michielstornebrink/> ;
  dc:contributor <https://www.linkedin.com/in/linda-oosterheert-006b0a10/> ;
  dc:creator <https://www.linkedin.com/in/jelte-bootsma-184634193/> ;
  dc:creator <https://www.linkedin.com/in/robin-de-veer/> ;
  dc:creator <https://www.linkedin.com/in/jeanine-de-graaf-beekhuis-7a9a4a151/> ;
  dc:description "The SHACL shapes/constraints associated with the SETU ontology."@en ;
  dc:modified "2026-02-05"^^xsd:date ;
  dc:title "SETU SHACL shapes" ;
  owl:versionInfo "2.9" ;
.
sh:property
  rdf:type owl:AnnotationProperty ;
.
hropen:AddressTypeArray
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:streetName ;
      sh:maxCount 1 ;
      sh:order 7 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:houseNumber ;
      sh:maxCount 1 ;
      sh:order 8 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:houseNumberAddition ;
      sh:maxCount 1 ;
      sh:order 9 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:buildingAddition ;
      sh:maxCount 1 ;
      sh:order 10 ;
    ] ;
.
hropen:Candidate
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:customer ;
      sh:description "The customer of the worker."@en ;
      sh:maxCount 1 ;
      sh:order 2 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:payRates ;
      sh:description "Container to specify the pay and/or bill rate the human resource is offered for."@en ;
      sh:order 8 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:reasonOfChange ;
      sh:maxCount 1 ;
      sh:order 13 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:resourceClassificationInclusion ;
      sh:maxCount 1 ;
      sh:order 11 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:staffingIds ;
      sh:maxCount 1 ;
      sh:order 12 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:supplier ;
      sh:description "The supplier of the worker."@en ;
      sh:maxCount 1 ;
      sh:order 1 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:customerSpecificRequirements ;
      sh:order 15 ;
    ] ;
.
hropen:CandidatePerson
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:residenceAddress ;
      sh:maxCount 1 ;
    ] ; 
.
hropen:CandidateProfile
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:workingPeriods ;
      sh:order 17 ;
    ] ; 
.
hropen:EmployerEstablishment
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path hropen:legalIdRef ;
      sh:datatype hropen:Identifier ;
      sh:description "A government assigned identifier to distinguish the party (organization, person, or legal entity) to a transaction."@en ;
      sh:maxCount 1 ;
    ] ; 
.
hropen:PayRate
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:multiplier ;
      sh:maxCount 1 ;
      sh:order 6 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:toBeBilled ;
      sh:maxCount 1 ;
      sh:order 7 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:toBePaid ;
      sh:maxCount 1 ;
      sh:order 8 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:purchaseOrderLineItem ;
      sh:description "The related purchase order line number."@en ;
      sh:maxCount 1 ;
      sh:order 10 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:rateType ;
      sh:maxCount 1 ;
      sh:order 1 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:period ;
      sh:maxCount 1 ;
      sh:order 5 ;
    ] ;
.
hropen:PersonCompetency
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:startDate ;
      sh:maxCount 1 ;
      sh:order 4 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:endDate ;
      sh:maxCount 1 ;
      sh:order 5 ;
    ] ;
.
hropen:PositionProfile
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:positionTask ;
      sh:maxCount 1 ;
      sh:order 4 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:origin ;
      sh:maxCount 1 ;
      sh:order 5 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:standByIndicator ;
      sh:maxCount 1 ;
      sh:order 6 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:requestedWorker ;
      sh:order 7 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:contractWorkingPeriods ;
      sh:order 22 ;
    ] ; 
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:positionReason ;
      sh:maxCount 1 ;
      sh:order 23 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:travelDistance ;
      sh:datatype xsd:decimal ;
      sh:maxCount 1 ;
      sh:order 25 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:collectiveLabourAgreement ;
      sh:maxCount 1 ;
      sh:order 26 ;
    ] ;
  sh:property [
    rdf:type sh:PropertyShape ;
    sh:path setu:salaryScale ;
    sh:maxCount 1 ;
    sh:order 27 ;
    ] ;
  sh:property [
    rdf:type sh:PropertyShape ;
    sh:path setu:referenceTitle ;
    sh:maxCount 1 ;
    sh:order 28 ;
    ] ;
  sh:property [
    rdf:type sh:PropertyShape ;
    sh:path setu:workDescription ;
    sh:maxCount 1 ;
    sh:order 29 ;
    ] ;
.
hropen:PositionProfile-positionPeriod
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path hropen:start ;
      sh:datatype xsd:date ;
      sh:description "The start date of the assignment on the position."@en ;
      sh:order 0 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path hropen:end ;
      sh:datatype xsd:date ;
      sh:order 1 ;
    ] ;
.
hropen:PositionQualification
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path hropen:certificationsRef ;
      sh:datatype hropen:Certification ;
      sh:description "Any certifications the person carries for the related position."@en ;
    ] ;
.
hropen:SpecifiedPerson
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path hropen:positionTitle ;
      sh:datatype hropen:PositionProfile-positionTitleDatatype ;
      sh:description "The title of the position of the contact person."@en ;
      sh:order 5 ;
    ] ;
.
hropen:Timecard
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:allowance ;
      sh:order 30 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:customer ;
      sh:description "The customer of the worker."@en ;
      sh:maxCount 1 ;
      sh:order 3 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:supplier ;
      sh:description "The supplier of the worker."@en ;
      sh:maxCount 1 ;
      sh:order 2 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:customerSpecificRequirements ;
      sh:order 35 ;
    ] ;
.
hropen:TimeCardItem
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:dayAssignment ;
      sh:maxCount 1 ;
      sh:order 40 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:homeOfficeIndicator ;
      sh:maxCount 1 ;
      sh:order 42 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:customerSpecificRequirements ;
      sh:order 43 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:quantity ;
      sh:description "Numerical quantity of the allowance or expense specified, assigned or determined by calculation or measurement."@en ;
      sh:maxCount 1 ;
      sh:order 33 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:attachment ;
      sh:description "The attachment or online reference to the proof of payment of an allowance/expense, for example a receipt of parking costs for reimbursement of these costs."@en ;
      sh:order 39 ;
    ] ;
.
hropen:WorkAssignment
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:assignedWorker ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:order 8 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:customer ;
      sh:description "The customer of the worker."@en ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:order 4 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:customerSpecificRequirements ;
      sh:order 11 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:payRates ;
      sh:description "Container to specify the agreed pay and/or bill rates applicable for the Assignment."@en ;
      sh:order 6 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:positionProfile ;
      sh:description "A profile of a position opening that is available at an organization."@en ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:order 7 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:staffingIds ;
      sh:maxCount 1 ;
      sh:order 9 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:supplier ;
      sh:description "The supplier of the worker."@en ;
      sh:maxCount 1 ;
      sh:order 3 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:resourceClassificationInclusion ;
      sh:maxCount 1 ;
      sh:order 5 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:reasonOfChange ;
      sh:maxCount 1 ;
      sh:order 10 ;
    ] ;
.
hropen:WorkingPeriod
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:effectiveTimePeriod ;
      sh:description "The period for which the agreed hours in the contract are valid."@en ;
      sh:order 4 ;
    ] ;
.
setu:AvailabilityLine
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:availabilityComment ;
      sh:maxCount 1 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:availabilityLineId ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:availabilityStatus ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
    ] ;
.
setu:AssignedWorker
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:assignedStatus ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:order 1 ;
    ] ;
  sh:property [
    rdf:type sh:PropertyShape ;
    sh:path setu:employeeContract ;
    sh:maxCount 1 ;
    sh:order 8 ;
    ] ;
  sh:property [
    rdf:type sh:PropertyShape ;
    sh:path setu:employeePhase ;
    sh:maxCount 1 ;
    sh:order 7 ;
    ] ;
  sh:property [
    rdf:type sh:PropertyShape ;
    sh:path setu:insuranceGroup ;
    sh:maxCount 1 ;
    sh:order 6 ;
    ] ;
  sh:property [
    rdf:type sh:PropertyShape ;
    sh:path setu:recruitedBy ;
    sh:maxCount 1 ;
    sh:order 11 ;
    ] ;
  sh:property [
    rdf:type sh:PropertyShape ;
    sh:path setu:vacationWorker ;
    sh:maxCount 1 ;
    sh:order 10 ;
    ] ;
  sh:property [
    rdf:type sh:PropertyShape ;
    sh:path setu:onCallContract ;
    sh:order 9 ;
    ] ;
.
setu:BaseAmount
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path hropen:unitCode ;
      sh:datatype xsd:string ;
      sh:description "The type code of the base amount."@en ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:order 0 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:baseType ;
      sh:maxCount 1 ;
      sh:order 1 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path hropen:value ;
      sh:datatype xsd:decimal ;
      sh:description "This element can be used to store additional information about the value of the base if applicable."@en ;
      sh:maxCount 1 ;
      sh:order 2 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path hropen:minValue ;
      sh:datatype xsd:decimal ;
      sh:description "If applicable, a minimum value can be provided to signify a minimum that the value in this base has to be. This implies that if the value is less than the minimum value, the minimum value will be used instead of the value element."@en ;
      sh:maxCount 1 ;
      sh:order 3 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path hropen:maxValue ;
      sh:datatype xsd:decimal ;
      sh:description "If applicable, a maximum value can be provided to signify a maximum that the value in this base has to be. This implies that if the value is more than the maximum value, the maximum value will be used instead of the value element."@en ;
      sh:maxCount 1 ;
      sh:order 4 ;
    ] ;
.
setu:BaseDefinition
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:baseType ;
      sh:description "A code to signify which base is defined here."@en ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:order 0 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:remunerationIndicator ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:order 1 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:holidayAllowanceIndicator ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:order 2 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:paidLeaveDayIndicator ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:order 3 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:allAllowancesIndicator ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:order 4 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:allowances ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:order 5 ;
    ] ;
.
setu:Breaks
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:breakTrigger ;
      sh:maxCount 1 ;
      sh:order 6 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:endDateTime ;
      sh:datatype xsd:dateTime ;
      sh:description "The end date and time of the break."@en ;
      sh:maxCount 1 ;
      sh:order 5 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:endTime ;
      sh:datatype "xsd:time" ;
      sh:description "The end time of the break."@en ;
      sh:maxCount 1 ;
      sh:order 3 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:paidOrUnpaid ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:order 1 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:startDateTime ;
      sh:datatype xsd:dateTime ;
      sh:description "The start date and time of the break."@en ;
      sh:maxCount 1 ;
      sh:order 4 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:startTime ;
      sh:datatype "xsd:time" ;
      sh:description "The start time of the break."@en ;
      sh:maxCount 1 ;
      sh:order 2 ;
    ] ;
.
setu:BreakTrigger
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:breakDuration ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:order 2 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:hours ;
      sh:datatype xsd:decimal ;
      sh:description "The amount of hours worked after which the break applies, expressed as decimal."@en ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:order 1 ;
    ] ;
.
setu:CareerLevel
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:indicator ;
      sh:description "A boolean indicating the presence of taking into account classification of career levels."@en ;
      sh:maxCount 1 ;
      sh:order 0 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:description ;
      sh:description "Description of the career levels."@en ;
      sh:maxCount 1 ;
      sh:order 1 ;
    ] ;
.
setu:CollectiveLabourAgreement
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:name ;
      sh:description "The name of the collective labour agreement (CLA)."@en ;
      sh:maxCount 1 ;
      sh:order 0 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path hropen:idRef ;
      sh:datatype hropen:Identifier ;
      sh:description "The identifier of the collective labour agreement (CLA)."@en ;
      sh:maxCount 1 ;
      sh:order 1 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:effectiveTimePeriod ;
      sh:description "The validity period of this specific collective labour agreement (version). The period is from the start date up to and including the end date."@en ;
      sh:maxCount 1 ;
      sh:order 2 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:basedOn ;
      sh:maxCount 1 ;
      sh:order 3 ;
    ] ;
.
setu:GeneralSalaryIncrease
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:effectiveTimePeriod ;
      sh:description "The effective start date of this initial increase."@en ;
      sh:maxCount 1 ;
      sh:order 0 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:remunerationAmount ;
      sh:description "Container element that contains the value of the amount and the type of unit of the value."@en ;
      sh:maxCount 1 ;
      sh:order 1 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:description ;
      sh:description "Free text description of the general salary table increase."@en ;
      sh:maxCount 1 ;
      sh:order 2 ;
    ] ;
.
setu:HourlyWageConversion
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:hourlyWageFactor ;
      sh:maxCount 1 ;
      sh:order 0 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:hourlyWagePercentage ;
      sh:maxCount 1 ;
      sh:order 1 ;
    ] ;
.
setu:Id
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:schemeAgencyId ;
      sh:datatype xsd:string ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:order 3 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:value ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:order 0 ;
    ] ;
.
setu:IncludedAllowances
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:typeCode ;
      sh:description "The codes of the allowances that are included in this base. A code specifying the type of allowance, such as ORT (irregularity allowance) or physical burden. There is a codelist with predefined allowances."@en ;
      sh:order 0 ;
    ] ;
.
setu:IndividualSalaryIncrease
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:effectiveTimePeriod ;
      sh:description "This element allows to specify on which date the salary adjustment or increase takes effect."@en ;
      sh:maxCount 1 ;
      sh:order 0 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:remunerationLine ;
      sh:maxCount 1 ;
      sh:order 1 ;
    ] ;
.
setu:IntervalCode
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path hropen:value ;
      sh:datatype xsd:string ;
      sh:description "The value can be used to express denominations of the provided interval code. If for instance it is required that the interval is every 15 minutes, the unit code can be 'Hour' and the value will be 0.25 as a quarter of 60 minutes is 15 minutes."@en ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:order 0 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path hropen:unitCode ;
      sh:datatype xsd:string ;
      sh:description "The unit code of the interval."@en ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:order 1 ;
    ] ;
.
setu:InquiryPayEquity
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path hropen:idRef ;
      sh:datatype hropen:Identifier ;
      sh:order 1 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
