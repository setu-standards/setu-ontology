    ] ;
.
inq:AmountLeaveDay
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path hropen:value ;
      sh:datatype xsd:decimal ;
      sh:description "The numerical value of the financial equivalent of one leave day. It reflects the cost or compensation value of a single day off from work."@en ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:order 0 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path hropen:minValue ;
      sh:datatype xsd:decimal ;
      sh:description "If applicable, a minimum value can be provided to signify a minimum that this rate provides. This implies that if the amount as a combination of the value and the base and the unit code is less than the minimum value, the minimum value will be used instead of the value element."@en ;
      sh:maxCount 1 ;
      sh:order 1 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path hropen:maxValue ;
      sh:datatype xsd:decimal ;
      sh:description "If applicable, a maximum value can be provided to signify a maximum that this rate provides. This implies that if the amount as a combination of the value and the base and the unit code is less than the maximum value, the maximum value will be used instead of the value element."@en ;
      sh:maxCount 1 ;
      sh:order 2 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:unitCode ;
      sh:datatype inq:AmountUnitCode ;
      sh:description "This element provides a way to specify the type of unit of the value. This can be for example 'percentage' if the unit type of the value is to be interpreted as a percentage or euro if the unity type of the value is to be interpreted as a euro monetary amount."@en ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:order 3 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path inq:baseAmount ;
      sh:description "This element stores information about the base over which the amount is calculated. If the value is 3, the unit code is 'Percentage' and the base code is 'MonthlySalary', together they would imply a 3% of monthly salary."@en ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:order 4 ;
    ] ;
