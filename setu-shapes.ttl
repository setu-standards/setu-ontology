inq:Arrangement
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path hropen:idRef ;
      sh:datatype hropen:Identifier ;
      sh:description "The unique identifier of this arrangement."@en ;
      sh:maxCount 1 ;
      sh:order 0 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:name ;
      sh:description "The name or description of the arrangement, indicating the type of arrangement and providing extra information that does not fit in any of the other fields."@en ;
      sh:maxCount 1 ;
      sh:order 1 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path inq:origin ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:order 2 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:effectivePeriod ;
      sh:description "Indicates the validity period of this arrangement. The period is from the start date up to and including the end date."@en ;
      sh:maxCount 1 ;
      sh:order 3 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:description ;
      sh:description "A free-text field for capturing additional details related to reward element (NL: beloningscomponent), such as specifics, limitations and other conditions."@en ;
      sh:maxCount 1 ;
      sh:order 25 ;
    ] ;
.
inq:ArrangementLine
  rdf:type sh:NodeShape ;
  sh:property [
