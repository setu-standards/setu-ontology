# baseURI: https://ontology.setu.nl/shapes#
# imports: https://ontology.setu.nl#
# prefix: setu

@prefix dc: <http://purl.org/dc/terms/> .
@prefix hropen: <https://hropenstandards.org/schema/xml/> .
@prefix inq: <https://ontology.setu.nl/inquiry-pay-equity#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix setu: <https://ontology.setu.nl#> .
@prefix setush: <https://ontology.setu.nl/shapes#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix sth: <https://ns.semantic-treehouse.nl/metadata/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://ontology.setu.nl/shapes#>
  rdf:type owl:Ontology ;
  owl:imports setu:, inq: ;
  dc:contributor <https://www.linkedin.com/in/michielstornebrink/> ;
  dc:contributor <https://www.linkedin.com/in/linda-oosterheert-006b0a10/> ;
  dc:creator <https://www.linkedin.com/in/jelte-bootsma-184634193/> ;
  dc:creator <https://www.linkedin.com/in/robin-de-veer/> ;
  dc:creator <https://www.linkedin.com/in/jeanine-de-graaf-beekhuis-7a9a4a151/> ;
  dc:description "The SHACL shapes/constraints associated with the SETU ontology."@en ;
  dc:modified "2026-03-04"^^xsd:date ;
  dc:title "SETU SHACL shapes" ;
  owl:versionInfo "2.9" ;
.
sh:property
  rdf:type owl:AnnotationProperty ;
.
hropen:AddressTypeArray
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:streetName ;
      sh:maxCount 1 ;
      sh:order 7 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:houseNumber ;
      sh:maxCount 1 ;
      sh:order 8 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:houseNumberAddition ;
      sh:maxCount 1 ;
      sh:order 9 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:buildingAddition ;
      sh:maxCount 1 ;
      sh:order 10 ;
    ] ;
.
hropen:Candidate
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:customer ;
      sh:datatype hropen:Party ;
      sh:description "The customer of the worker."@en ;
      sh:maxCount 1 ;
      sh:order 2 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:payRates ;
      sh:description "Container to specify the pay and/or bill rate the human resource is offered for."@en ;
      sh:order 8 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:reasonOfChange ;
      sh:maxCount 1 ;
      sh:order 13 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:resourceClassificationInclusion ;
      sh:maxCount 1 ;
      sh:order 11 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:staffingIds ;
      sh:maxCount 1 ;
      sh:order 12 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:supplier ;
      sh:description "The supplier of the worker."@en ;
      sh:maxCount 1 ;
      sh:order 1 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:customerSpecificRequirements ;
      sh:order 15 ;
    ] ;
.
hropen:CandidatePerson
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:residenceAddress ;
      sh:maxCount 1 ;
    ] ; 
.
hropen:CandidateProfile
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:workingPeriods ;
      sh:order 17 ;
    ] ; 
.
hropen:EmployerEstablishment
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path hropen:legalIdRef ;
      sh:datatype hropen:Identifier ;
      sh:description "A government assigned identifier to distinguish the party (organization, person, or legal entity) to a transaction."@en ;
      sh:maxCount 1 ;
    ] ; 
.
hropen:PayRate
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:multiplier ;
      sh:maxCount 1 ;
      sh:order 6 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:toBeBilled ;
      sh:maxCount 1 ;
      sh:order 7 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:toBePaid ;
      sh:maxCount 1 ;
      sh:order 8 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:purchaseOrderLineItem ;
      sh:description "The related purchase order line number."@en ;
      sh:maxCount 1 ;
      sh:order 10 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:rateType ;
      sh:maxCount 1 ;
      sh:order 1 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:period ;
      sh:datatype hropen:Period ;
      sh:description "Container to specify the period in which the pay rate is valid."@en ;
      sh:maxCount 1 ;
      sh:order 5 ;
    ] ;
.
hropen:PersonCompetency
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:startDate ;
      sh:maxCount 1 ;
      sh:order 4 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:endDate ;
      sh:maxCount 1 ;
      sh:order 5 ;
    ] ;
.
hropen:PositionProfile
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:positionTask ;
      sh:maxCount 1 ;
      sh:order 4 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path inq:origin ;
      sh:maxCount 1 ;
      sh:order 5 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:standByIndicator ;
      sh:maxCount 1 ;
      sh:order 6 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:requestedWorker ;
      sh:order 7 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:contractWorkingPeriods ;
      sh:order 22 ;
    ] ; 
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:positionReason ;
      sh:maxCount 1 ;
      sh:order 23 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:travelDistance ;
      sh:datatype xsd:decimal ;
      sh:maxCount 1 ;
      sh:order 25 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:collectiveLabourAgreement ;
      sh:maxCount 1 ;
      sh:order 26 ;
    ] ;
  sh:property [
    rdf:type sh:PropertyShape ;
    sh:path setu:salaryScale ;
    sh:maxCount 1 ;
    sh:order 27 ;
    ] ;
  sh:property [
    rdf:type sh:PropertyShape ;
    sh:path setu:referenceTitle ;
    sh:maxCount 1 ;
    sh:order 28 ;
    ] ;
  sh:property [
    rdf:type sh:PropertyShape ;
    sh:path setu:workDescription ;
    sh:maxCount 1 ;
    sh:order 29 ;
    ] ;
.
hropen:PositionProfile-positionPeriod
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path hropen:start ;
      sh:datatype xsd:date ;
      sh:description "The start date of the assignment on the position."@en ;
      sh:order 0 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path hropen:end ;
      sh:datatype xsd:date ;
      sh:order 1 ;
    ] ;
.
hropen:PositionQualification
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path hropen:certificationsRef ;
      sh:datatype hropen:Certification ;
      sh:description "Any certifications the person carries for the related position."@en ;
    ] ;
.
hropen:Timecard
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:allowance ;
      sh:order 30 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:customer ;
      sh:datatype hropen:Party ;
      sh:description "The customer of the worker."@en ;
      sh:maxCount 1 ;
      sh:order 3 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:supplier ;
      sh:description "The supplier of the worker."@en ;
      sh:maxCount 1 ;
      sh:order 2 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:customerSpecificRequirements ;
      sh:order 35 ;
    ] ;
.
hropen:TimeCardItem
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:dayAssignment ;
      sh:maxCount 1 ;
      sh:order 40 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:homeOfficeIndicator ;
      sh:maxCount 1 ;
      sh:order 42 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:customerSpecificRequirements ;
      sh:order 43 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:quantity ;
      sh:description "Numerical quantity of the allowance or expense specified, assigned or determined by calculation or measurement."@en ;
      sh:maxCount 1 ;
      sh:order 33 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:attachment ;
      sh:description "The attachment or online reference to the proof of payment of an allowance/expense, for example a receipt of parking costs for reimbursement of these costs."@en ;
      sh:order 39 ;
    ] ;
.
hropen:WorkAssignment
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:assignedWorker ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:order 8 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:customer ;
      sh:datatype hropen:Party ;
      sh:description "The customer of the worker."@en ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:order 4 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:customerSpecificRequirements ;
      sh:order 11 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:payRates ;
      sh:description "Container to specify the agreed pay and/or bill rates applicable for the Assignment."@en ;
      sh:order 6 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:positionProfile ;
      sh:description "A profile of a position opening that is available at an organization."@en ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:order 7 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:staffingIds ;
      sh:maxCount 1 ;
      sh:order 9 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:supplier ;
      sh:description "The supplier of the worker."@en ;
      sh:maxCount 1 ;
      sh:order 3 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:resourceClassificationInclusion ;
      sh:maxCount 1 ;
      sh:order 5 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:reasonOfChange ;
      sh:maxCount 1 ;
      sh:order 10 ;
    ] ;
.
hropen:WorkingPeriod
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:effectiveTimePeriod ;
      sh:description "The period for which the agreed hours in the contract are valid."@en ;
      sh:order 4 ;
    ] ;
.
inq:AllowanceArrangement
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path inq:typeCode ;
      sh:datatype inq:AllowanceCode ;
      sh:description "A code specifying the type of allowance."@en ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:order 4 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:period ;
      sh:datatype setu:Period;
      sh:description "A container element that specifies the time period(s) during which the allowance is applicable. It includes a date period (which can be used for date ranges or individual dates), a time period (given the selected dates, this lets us specify the allowed times) and a weekday element that lets us specify recurring days of the week."@en ;
      sh:order 5 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path inq:arrangementLine ;
      sh:datatype inq:ArrangementLine ;
      sh:order 10 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path inq:payDate ;
      sh:description "If the employer has a specific pay date for the allowance, it can be specified here. If only the start is provided, the pay date is a specific date. If a start and an end date are provided, the payment can be made somewhere in this date range."@en ;
      sh:maxCount 1 ;
      sh:order 11 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path inq:reference ;
      sh:order 12 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path inq:phaseOutScheme ;
      sh:maxCount 1 ;
      sh:order 13 ;
    ] ;
.
inq:AllowanceReference
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path inq:typeCode ;
      sh:datatype inq:AllowanceCode ;
      sh:description "The codes of the allowances that are included in this base. A code specifying the type of allowance, such as ORT (irregularity allowance) or physical burden. There is a codelist with predefined allowances."@en ;
      sh:maxCount 1 ;
      sh:order 0 ;
    ] ;
.
inq:AllowanceReferenceExtended
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path hropen:idRef ;
      sh:datatype hropen:Identifier ;
      sh:description "The unique identifier that references a specific arrangement or a specific rule within an arrangement."@en ;
      sh:maxCount 1 ;
      sh:order 0 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path inq:typeCode ;
      sh:datatype inq:AllowanceCode ;
      sh:description "The type code of the object that is referred to. If for instance this rate has to be calculated before any overwork rates can be calculated, this element would contain the code for overwork."@en ;
      sh:maxCount 1 ;
      sh:order 1 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:description ;
      sh:description "A description of the nature of the relation."@en ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:order 2 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path inq:relationType ;
      sh:description "The code of the type of relation that this reference is."@en ;
      sh:maxCount 1 ;
      sh:order 3 ;
    ] ;
.
inq:Amount
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path hropen:value ;
      sh:datatype xsd:decimal ;
      sh:description "The numerical value of the remuneration amount expressed as decimal. The unit type of this value can be specified in the unit code element."@en ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:order 0 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path hropen:minValue ;
      sh:datatype xsd:decimal ;
      sh:description "If applicable, a minimum value can be provided to signify a minimum that this rate provides. This implies that if the amount as a combination of the value and the base and the unit code is less than the minimum value, the minimum value will be used instead of the value element."@en ;
      sh:maxCount 1 ;
      sh:order 1 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path hropen:maxValue ;
      sh:datatype xsd:decimal ;
      sh:description "If applicable, a maximum value can be provided to signify a maximum that this rate provides. This implies that if the amount as a combination of the value and the base and the unit code is less than the maximum value, the maximum value will be used instead of the value element."@en ;
      sh:maxCount 1 ;
      sh:order 2 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:unitCode ;
      sh:datatype inq:AmountUnitCode ;
      sh:description "This element provides a way to specify the type of unit of the value. This can be for example 'percentage' if the unit type of the value is to be interpreted as a percentage or euro if the unity type of the value is to be interpreted as a euro monetary amount."@en ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:order 3 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path inq:baseAmount ;
      sh:description "This element stores information about the base over which the amount is calculated. If the value is 3, the unit code is 'Percentage' and the base code is 'MonthlySalary', together they would imply a 3% of monthly salary."@en ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:order 4 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path inq:proportional ;
      sh:maxCount 1 ;
      sh:order 5 ;
    ] ;
.
inq:AmountLimited
  rdf:type sh:NodeShape ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path hropen:value ;
      sh:datatype xsd:decimal ;
      sh:description "The value of the amount."@en ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:order 0 ;
    ] ;
  sh:property [
      rdf:type sh:PropertyShape ;
      sh:path setu:unitCode ;
      sh:datatype setu:UnitCode ;
      sh:description "This element provides a way to specify the type of unit of the value. This can be for example 'percentage' if the unit type of the value is to be interpreted as a percentage or euro if the unity type of the value is to be interpreted as a euro monetary amount."@en ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:order 1 ;
    ] ;
.
