  rdf:type owl:AnnotationProperty ;
.
hropen:Identifier
  rdf:type owl:Class ;
.
hropen:Identifier-schemeAgencyIdDatatype
  skos:definition "The organization that issues the identifier. This organization is also responsible for unicity of the identifier within its own context."@en ;
.
hropen:Identifier-valueDatatype
  skos:definition "The value of the unique identifier."@en ;
.
hropen:Noun
  rdf:type owl:Class ;
.
hropen:Party
  rdf:type owl:Class ;
  rdf:type sh:NodeShape ;
  rdfs:subClassOf owl:Thing ;
.
hropen:PositionProfile
  rdf:type owl:Class ;
.
hropen:Text
  rdf:type owl:Class ;
.
hropen:WorkAssignment
  rdf:type owl:Class ; 
  rdfs:subClassOf hropen:Noun ;
.
hropen:Worker
  rdf:type owl:Class ;
.
inq:
  rdf:type owl:Ontology ;
  dc:contributor <https://www.linkedin.com/in/michielstornebrink/> ;
  dc:contributor <https://www.linkedin.com/in/jelte-bootsma-184634193/> ;
  dc:creator <https://www.linkedin.com/in/robin-de-veer/> ;
  dc:description "The Inquiry Pay Equity module of the SETU ontology includes concepts created from the SETU context used in the SETU Inquiry Pay Equity standard."@en ;
  dc:modified "2026-03-02"^^xsd:date ;
  dc:title "SETU Inquiry Pay Equity module" ;
  owl:versionInfo "0.9" ;
.
inq:AllowanceArrangement
  rdf:type owl:Class ;
  rdfs:subClassOf inq:Arrangement ;
  rdfs:label "Allowance arrangement"@en ;
.
inq:AllowanceCode
  rdf:type rdfs:Datatype ;
  rdfs:label "Allowance code" ;
  rdfs:subClassOf xsd:string ;
  owl:onDatatype xsd:string ;
.
inq:AllowanceReference
  rdf:type owl:Class ;
  rdfs:label "Allowance reference"@en ;
.
inq:AllowanceReferenceExtended
  rdf:type owl:Class ;
  rdfs:label "Allowance reference"@en ;
.
inq:Amount
  rdf:type owl:Class ;
  rdfs:label "Amount"@en ;
  skos:definition "Container element that contains the value of the amount, the type of unit of the value and a base. These three elements together can be used to calculate the amount of any type of rate. If applicable, a minimum and a maximum value can also be provided to signify a minimum and maximum that this rate provides. This implies that if the amount as a combination of the value and the base and the unit code is less than the minimum value, the minimum value will replace the value element."@en ;
.
inq:AmountExtended
  rdf:type owl:Class ;
  rdfs:label "Amount extended"@en ;
  skos:definition "Container element that contains the value of the amount, the type of unit of the value and a base. These three elements together can be used to calculate the amount of any type of rate. If applicable, a minimum and a maximum value can also be provided to signify a minimum and maximum that this rate provides. This implies that if the amount as a combination of the value and the base and the unit code is less than the minimum value, the minimum value will replace the value element."@en ;
.
inq:AmountLimited
  rdf:type owl:Class ;
  rdfs:label "Amount limited"@en ;
  skos:definition "Container element that contains the value of the amount and the type of unit of the value."@en ;
.
inq:AmountUnitCode
  rdf:type rdfs:Datatype ;
  rdfs:subClassOf setu:UnitCode ;
  rdfs:label "Amount unit code" ;
  sth:allowedValue "Euro" ;
  sth:allowedValue "Hour" ;
  sth:allowedValue "Percentage" ;
.
inq:AmountUnitCodeExtended
  rdf:type rdfs:Datatype ;
  rdfs:subClassOf setu:UnitCode ;
  rdfs:label "Amount unit code extended" ;
  sth:allowedValue "Day" ;
  sth:allowedValue "Euro" ;
  sth:allowedValue "Hour" ;
  sth:allowedValue "Percentage" ;
  sth:allowedValue "SalaryStep" ;
.
inq:Arrangement
  rdf:type owl:Class ;
  rdfs:type "Arrangement"@en ;
  skos:definition "Class to specify an arrangement."@en ;
.
inq:ArrangementLine
  rdf:type owl:Class ;
  rdfs:label "Arrangement line"@en ;
  skos:definition "A container that contains the details of the rate to be applied for the remuneration component. It includes elements such as the amount that is provided, the interval in which this is applied in the specified period (e.g. each year) and any conditions that might have to be met for this rate to be applicable."@en ;
.
inq:ArrangementLineExtended
  rdf:type owl:Class ;
  rdfs:label "Arrangement line extended"@en ;
  skos:definition "A container that contains the details of the rate to be applied for the remuneration component. It includes elements such as the amount that is provided, the interval in which this is applied in the specified period (e.g. each year) and any conditions that might have to be met for this rate to be applicable."@en ;
.
inq:ArrangementLineLimited
  rdf:type owl:Class ;
  rdfs:label "Arrangement line limited"@en ;
  skos:definition "A container that contains the details of the increase rate. It includes elements such as the amount that is provided, the interval in which this is applied in the specified period (e.g. each year) and any conditions that might have to be met for this rate to be applicable."@en ;
.
inq:BaseAmount
  rdf:type owl:Class ;
  rdfs:label "Base amount"@en ;
  skos:definition "This element stores information about the base over which the amount is calculated."@en ;
.
inq:BaseDefinition
  rdf:type owl:Class ;
  rdfs:label "Base definition"@en ;
  skos:definition "Definitions of the bases (in Dutch: 'Grondslagen') that can be used to calculate the different rates."@en ;
.
inq:BaseDefinitionCode
  rdf:type rdfs:Datatype ;
  rdfs:label "Base definition code" ;
  rdfs:subClassOf xsd:string ;
  owl:onDatatype xsd:string ;
.
inq:BaseUnitCode
  rdf:type rdfs:Datatype ;
  rdfs:subClassOf setu:UnitCode ;
  rdfs:label "Base unit code" ;
.
inq:CareerLevel
  rdf:type owl:Class ;
  rdfs:label "Career level"@en ;
.
inq:Condition
  rdf:type owl:Class ;
  rdfs:label "Condition"@en ;
  skos:definition "A container element for providing more information about a condition that has to be met before a rate is applied. An employee that meets these conditions is eligible for the rate."@en ;
.
inq:GeneralSalaryIncrease
  rdf:type owl:Class ;
  rdfs:label "General salary increase"@en ;
  skos:definition "The general salary adjustment refers to the increase applied uniformly to the entire salary table. This adjustment ensures that all employees receive a consistent percentage or fixed increase in their salaries."@en ;
.
inq:HolidayAllowanceArrangement
  rdf:type owl:Class ;
  rdfs:subClassOf inq:Arrangement ;
  rdfs:label "Holiday allowance arrangement"@en ;
.
inq:HourlyWageConversion
  rdf:type owl:Class ;
  rdfs:label "Hourly wage conversion"@en ;
  skos:definition "Information about the conversion to regular hourly wages."@en ;
.
inq:IkbReference
  rdf:type owl:Class ;
  rdfs:label "Ikb reference"@en ;
  skos:definition "Container element to refer how a renumeration element connects to 'het Individueel Keuze Budget' (EN: Individual Choice Budget)."@en ;
.
inq:IndividualChoiceBudgetArrangement
  rdf:type owl:Class ;
  rdfs:subClassOf inq:Arrangement ;
  rdfs:label "Individual choice budget arrangement"@en ;
.
inq:IndividualChoiceBudgetOption
  rdf:type owl:Class ;
  rdfs:label "Individual choice budget option"@en ;
.
inq:IndividualSalaryIncrease
  rdf:type owl:Class ;
  rdfs:label "Individual salary increase"@en ;
  skos:definition "The individual salary review is a process where an employee's salary is evaluated and adjusted based on individual performance, and other relevant criteria. This container specifies the increase rate of these adjustments."@en ;
.
inq:InquiryPayEquity
  rdf:type owl:Class ;
  rdfs:label "Inquiry pay equity"@en ;
  rdfs:subClassOf hropen:Noun ;
  skos:definition "The Inquiry Pay Equity message is used by the staffing customer to exchange remuneration information with the staffing supplier in order to accurately apply equal pay for flex workers according to the staffing customer's collective labor agreement."@en ;
.
inq:Interval
  rdf:type owl:Class ;
  rdfs:label "Interval" ;
  skos:definition "The interval block specifies the period over which these hours apply."@en ;
.
inq:IntervalCode
  rdf:type rdfs:Datatype ;
  rdfs:subClassOf setu:UnitCode ;
  rdfs:label "Interval code" ;
.
inq:IntervalHourUnitCode
  rdf:type rdfs:Datatype ;
  rdfs:subClassOf setu:UnitCode ;
  rdfs:label "Interval hour unit code" ;
  sth:allowedValue "Hour" ;
.
inq:IntervalHourDayUnitCode
  rdf:type rdfs:Datatype ;
  rdfs:subClassOf setu:UnitCode ;
  rdfs:label "Interval hour day unit code" ;
  sth:allowedValue "Day" ;
  sth:allowedValue "Hour" ;
.
inq:LabourAgreementReference
  rdf:type owl:Class ;
  rdfs:label "Labour agreement reference"@en ;
  skos:definition "Contains references to the labour agreement applicable."@en ;
.
inq:LabourAgreements
  rdf:type owl:Class ;
  rdfs:label "Labour agreements"@en ;
  skos:definition "This container indicates in which sector the staffing customer works and which specific collective labour agreement (CLA) and/or the own employment conditions scheme is leading for the provision of remuneration information."@en ;
.
inq:LeaveArrangement
  rdf:type owl:Class ;
  rdfs:label "Leave arrangement"@en ;
.
inq:OtherArrangement
  rdf:type owl:Class ;
  rdfs:subClassOf inq:Arrangement ;
  rdfs:label "Other arrangement"@en ;
.
inq:PensionArrangement
  rdf:type owl:Class ;
  rdfs:subClassOf inq:Arrangement ;
  rdfs:label "Pension arrangement"@en ;
.
inq:PositionProfileReference
  rdf:type owl:Class ;
  rdfs:label "Position profile reference"@en ;
  skos:definition "Reference to the applicable position profile."@en ;
.
inq:Proportional
  rdf:type owl:Class ;
  rdfs:label "Proportional"@en ;
  skos:definition "The proportional element is used to specify whether certain work-related conditions such as leave entitlements, remuneration, or similar employment provisions are applied proportionally based on specific employee characteristics."@en ;
.
inq:RemunerationPackage
  rdf:type owl:Class ;
  rdfs:label "Remuneration package"@en ;
  skos:definition "Details about the remuneration package, including salary tables based on the work duration. It includes one or more salary tables for a specific work duration or characteristics."@en ;
.
inq:SalaryScale
  rdf:type owl:Class ;
  rdfs:label "Salary scale"@en ;
.
inq:SalaryScaleStep
  rdf:type owl:Class ;
  rdfs:label "Salary scale step"@en ;
.
inq:SickPayArrangement
  rdf:type owl:Class ;
  rdfs:subClassOf inq:Arrangement ;
  rdfs:label "Sick pay arrangement"@en ;
.
inq:SupplementaryArrangement
  rdf:type owl:Class ;
  rdfs:subClassOf inq:Arrangement ;
  rdfs:label "Supplementary arrangement"@en ;
.
inq:SupplementaryArrangementCode
  rdf:type rdfs:Datatype ;
  rdfs:label "Supplementary arrangement code" ;
  rdfs:subClassOf xsd:string ;
  owl:onDatatype xsd:string ;
.
inq:SustainabilityCode
  rdf:type rdfs:Datatype ;
  rdfs:label "Sustainability code" ;
  rdfs:subClassOf xsd:string ;
  owl:onDatatype xsd:string ;
.
inq:SustainableEmployabilityArrangement
  rdf:type owl:Class ;
  rdfs:subClassOf inq:Arrangement ;
  rdfs:label "Sustainable employability arrangement"@en ;
.
inq:WaitingDays
  rdf:type owl:Class ;
  rdfs:label "Waiting days" ;
.
inq:WorkDuration
  rdf:type owl:Class ;
  rdfs:label "Work duration"@en ;
  skos:definition "Specifies the default work duration."@en ;
.
inq:allAllowancesIndicator
  rdf:type owl:DatatypeProperty ;
  rdfs:label "all allowances indicator"@en ;
  rdfs:range xsd:boolean ;
  skos:definition "This element can be used to indicate whether allowances are taken into consideration for calculating this base. If 'True', then all allowances are taken into account. If 'False', the allowances that are taken into account can be specified in the 'allowances' element."@en ;
  sth:xmlTag "allAllowancesIndicator" ;
.
inq:allowanceArrangement
  rdf:type owl:ObjectProperty ;
  rdfs:domain inq:InquiryPayEquity ;
  rdfs:label "allowance"@en ;
  rdfs:range inq:AllowanceArrangement ;
  skos:definition "A container element that includes various allowances that can be granted to an employee."@en ;
  sth:xmlTag "allowanceArrangement" ;
.
inq:allowances
  rdf:type owl:ObjectProperty ;
  rdfs:label "allowances"@en ;
  rdfs:range inq:AllowanceReference ;
  skos:definition "A list of allowances that are included in this base."@en ;
  sth:xmlTag "allowances" ;
.
inq:amount
  rdf:type owl:ObjectProperty ;
  rdfs:label "amount"@en ;
  skos:definition "Container element that contains the value of the amount, the type of unit of the value and a base. These three elements together can be used to calculate the amount of any type of rate. If applicable, a minimum and a maximum value can also be provided to signify a minimum and maximum that this rate provides. This implies that if the amount as a combination of the value and the base and the unit code is less than the minimum value, the minimum value will replace the value element."@en ;
  sth:xmlTag "amount" ;
.
inq:arrangementLine
  rdf:type owl:ObjectProperty ;
  rdfs:label "line"@en ;
  skos:definition "A container that contains the details of the rate to be applied for the remuneration component. It includes elements such as the amount that is provided, the interval in which this is applied in the specified period (e.g. each year) and any conditions that might have to be met for this rate to be applicable."@en ;
  sth:xmlTag "arrangementLine" ;
.
inq:baseAmount
  rdf:type owl:ObjectProperty ;
  rdfs:label "base amount"@en ;
  rdfs:range inq:BaseAmount ;
  skos:definition "This element stores information about the base over which the amount is calculated."@en ;
  sth:xmlTag "baseAmount" ;
.
inq:baseDefinition
  rdf:type owl:ObjectProperty ;
  rdfs:domain inq:InquiryPayEquity ;
  rdfs:label "base definition"@en ;
  rdfs:range inq:BaseDefinition ;
  skos:definition "Definitions of the bases (in Dutch: 'Grondslagen') that can be used to calculate the different rates."@en ;
  sth:xmlTag "baseDefinition" ;
.
inq:baseType
  rdf:type owl:DatatypeProperty ;
  rdfs:label "base type"@en ;
  rdfs:range inq:BaseDefinitionCode ;
  skos:definition "Base type definition. Refers to the base over which this amount was calculated."@en ;
  sth:xmlTag "baseType" ;
.
inq:careerLevel
  rdf:type owl:ObjectProperty ;
  rdfs:label "career level"@en ;
  rdfs:range inq:CareerLevel ;
  skos:definition "Indicates whether work experience is considered in the salary scale, with a true or false value and a possible description."@en ;
  sth:xmlTag "careerLevel" ;
.
inq:conditions
  rdf:type owl:ObjectProperty ;
  rdfs:label "conditions"@en ;
  rdfs:range inq:Condition ;
  skos:definition "A container element for providing more information about the conditions that have to be met before this rate is applied. An employee that meets these conditions is eligible for the rate."@en ;
  sth:xmlTag "conditions" ;
.
inq:effectiveDate
  rdf:type owl:ObjectProperty ;
  rdfs:label "effective date"@en ;
  rdfs:range setu:Occurrence ;
  skos:definition "This element allows us to specify on which date the salary adjustment or increase takes effect."@en ;
  sth:xmlTag "effectiveDate" ;
.
inq:employmentDuration
  rdf:type owl:DatatypeProperty ;
  rdfs:domain inq:Proportional ;
  rdfs:label "employment duration"@en ;
  rdfs:range xsd:boolean ;
  skos:definition "Indicates whether proportional calculation must be applied according to the employee's length of employment."@en ;
  sth:xmlTag "employmentDuration" ;
.
inq:generalSalaryIncrease
  rdf:type owl:ObjectProperty ;
  rdfs:domain inq:RemunerationPackage ;
  rdfs:label "general salary increase"@en ;
  rdfs:range inq:GeneralSalaryIncrease ;
  skos:definition "The general salary adjustment refers to the increase applied uniformly to the entire salary table. This adjustment ensures that all employees receive a consistent percentage or fixed increase in their salaries. Please mind the usage note when to use this container."@en ;
  sth:xmlTag "generalSalaryIncrease" ;
.
inq:holidayAllowanceArrangement
  rdf:type owl:ObjectProperty ;
  rdfs:domain inq:InquiryPayEquity ;
  rdfs:label "holiday allowance"@en ;
  rdfs:range inq:HolidayAllowanceArrangement ;
  skos:definition "A container that contains the details of the holiday allowance arrangement."@en ;
  sth:xmlTag "holidayAllowanceArrangement" ;
.
inq:holidayAllowanceIndicator
  rdf:type owl:DatatypeProperty ;
  rdfs:label "holiday allowance indicator"@en ;
  rdfs:range xsd:boolean ;
  skos:definition "This element can be used to indicate whether holiday allowance(s) is/are taken into consideration for calculating this base."@en ;
  sth:xmlTag "holidayAllowanceIndicator" ;
.
inq:hourlyWageConversion
  rdf:type owl:ObjectProperty ;
  rdfs:domain inq:RemunerationPackage ;
  rdfs:label "hourly wage conversion"@en ;
  rdfs:range inq:HourlyWageConversion ;
  skos:definition "Information about the conversion to regular hourly wages."@en ;
  skos:note "It is possible that hourly conversion rates differ on the step/cell level. If this is the case for one or more steps/cells, then add a salary table that describes the remuneration per hour." ;
  skos:note "If your employment conditions or collective labour agreement do not specify hourly wages or a clear calculation method, the hourly wage is calculated as follows: monthly salary / (4.35 x normal working hours)." ;
  sth:xmlTag "hourlyWageConversion" ;
.
inq:hourlyWageFactor
  rdf:type owl:DatatypeProperty ;
  rdfs:domain inq:HourlyWageConversion ;
  rdfs:label "hourly wage factor"@en ;
  rdfs:range xsd:decimal ;
  skos:definition "A number used to calculate the hourly wage from a periodic salary (e.g., monthly salary). The periodic salary is divided by this factor to determine the hourly wage. Formula: hourly wage = periodic salary / hourlyWageFactor."@en ;
  skos:note "It is possible that hourly conversion rates differ on the step/cell level. If this is the case for one or more steps/cells, then add a salary table that describes the remuneration per hour." ;
  sth:xmlTag "hourlyWageFactor" ;
.
inq:hourlyWagePercentage
  rdf:type owl:DatatypeProperty ;
  rdfs:domain inq:HourlyWageConversion ;
  rdfs:label "hourly wage percentage"@en ;
  rdfs:range xsd:decimal ;
  skos:definition "A percentage that the periodic salary (such as a monthly salary) is multiplied by to calculate the hourly wage. Formula: hourly wage = (periodic salary * hourlyWagePercentage) / 100."@en ;
  skos:note "It is possible that hourly conversion rates differ on the step/cell level. If this is the case for one or more steps/cells, then add a salary table that describes the remuneration per hour." ;
  sth:xmlTag "hourlyWagePercentage" ;
.
inq:ikbReference
  rdf:type owl:ObjectProperty ;
  rdfs:label "ikb reference"@en ;
  rdfs:range inq:IkbReference ;
  skos:definition "Container element to refer how a renumeration element connects to 'het Individueel Keuze Budget' (EN: Individual Choice Budget)."@en ;
  sth:xmlTag "ikbReference" ;
.
inq:individualChoiceBudgetArrangement
  rdf:type owl:ObjectProperty ;
  rdfs:domain inq:InquiryPayEquity ;
  rdfs:label "individual choice budget"@en ;
  rdfs:range inq:IndividualChoiceBudgetArrangement ;
  skos:definition "Individual choice budget (Dutch: IKB) is used if the employer has an individual choice budget. It's elements are used for the different options an employee has regarding this budget as well as its costs."@en ;
  sth:xmlTag "individualChoiceBudgetArrangement" ;
.
inq:individualSalaryIncrease
  rdf:type owl:ObjectProperty ;
  rdfs:domain inq:RemunerationPackage ;
  rdfs:label "individual salary increase"@en ;
  rdfs:range inq:IndividualSalaryIncrease ;
  skos:definition "The individual salary review is a process where an employee's salary is evaluated and adjusted based on individual performance, and other relevant criteria. This container specifies the increase rate of these adjustments."@en ;
  sth:xmlTag "individualSalaryIncrease" ;
.
inq:interval
  rdf:type owl:ObjectProperty ;
  rdfs:label "interval"@en ;
  rdfs:range inq:Interval ;
  sth:xmlTag "interval" ;
.
inq:labourAgreements
  rdf:type owl:ObjectProperty ;
  rdfs:label "labour agreements"@en ;
  rdfs:range inq:LabourAgreements ;
  skos:definition "Indicates in which sector the staffing customer works and which specific collective labour agreement (CLA) and/or the own employment conditions scheme is leading for the provision of remuneration information."@en ;
  sth:xmlTag "labourAgreements" ;
.
inq:leaveArrangement
  rdf:type owl:ObjectProperty ;
  rdfs:domain inq:InquiryPayEquity ;
  rdfs:label "leave"@en ;
  rdfs:range inq:LeaveArrangement ;
  skos:definition "A container that contains the details of the leave arrangement, such as the type of leave, the amount of the leave, as well as any conditions."@en ;
  sth:xmlTag "leaveArrangement" ;
.
inq:minimumWage
  rdf:type owl:DatatypeProperty ;
  rdfs:label "minimum wage"@en ;
  rdfs:range xsd:boolean ;
  skos:definition "A boolean that indicates whether this salary step is equal to the minimum wage."@en ;
  sth:xmlTag "minimumWage" ;
.
inq:option
  rdf:type owl:ObjectProperty ;
  rdfs:label "option"@en ;
  rdfs:range inq:IndividualChoiceBudgetOption ;
  skos:definition "Associates the different rates on how this individual choice budget can be spent (e.g. the percentage of salary that one extra day of vacation costs)."@en ;
  sth:xmlTag "option" ;
.
inq:origin
  rdf:type owl:ObjectProperty ;
  rdfs:label "origin"@en ;
  rdfs:range inq:LabourAgreementReference ;
  skos:definition "Specifies the origin of the applicable agreement."@en ;
  sth:xmlTag "origin" ;
.
inq:otherArrangement
  rdf:type owl:ObjectProperty ;
  rdfs:domain inq:InquiryPayEquity ;
  rdfs:label "other arrangement"@en ;
  rdfs:range inq:OtherArrangement ;
  skos:definition "This element can be used to provide any additional arrangements that have not been covered by the other elements."@en ;
  sth:xmlTag "otherArrangement" ;
.
inq:paidLeaveDayIndicator
  rdf:type owl:DatatypeProperty ;
  rdfs:label "paid leave day indicator"@en ;
  rdfs:range xsd:boolean ;
  skos:definition "This element can be used to indicate whether paid leave days are taken into consideration for calculating this base."@en ;
  sth:xmlTag "paidLeaveDayIndicator" ;
.
inq:partTimePercentage
  rdf:type owl:DatatypeProperty ;
  rdfs:domain inq:Proportional ;
  rdfs:label "part time percentage"@en ;
  rdfs:range xsd:boolean ;
  skos:definition "Indicates whether the condition is calculated proportionally based on the employee's part-time percentage, typically measured against a full-time work week (commonly 36-40 hours)."@en ;
  sth:xmlTag "partTimePercentage" ;
.
inq:payDate
  rdf:type owl:ObjectProperty ;
  rdfs:label "pay date"@en ;
  rdfs:range setu:Occurrence ;
  sth:xmlTag "payDate" ;
.
inq:pensionArrangement
  rdf:type owl:ObjectProperty ;
  rdfs:domain inq:InquiryPayEquity ;
  rdfs:label "pension"@en ;
  rdfs:range inq:PensionArrangement ;
  skos:definition "The employer's contribution to a pension plan."@en ;
  sth:xmlTag "pensionArrangement" ;
.
inq:phaseOutScheme
  rdf:type owl:DatatypeProperty ;
  rdfs:label "phase out scheme"@en ;
  rdfs:range xsd:string ;
  skos:definition "If this allowance has a phasing out scheme arrangement, this can be described in this element."@en ;
  sth:xmlTag "phaseOutScheme" ;
.
inq:positionProfileReference
  rdf:type owl:ObjectProperty ;
  rdfs:label "position profile reference"@en ;
  rdfs:range inq:PositionProfileReference ;
  skos:definition "Refers to the position profile that this salary scale is applied to. This element refers to the 'positionId/value' element in the corresponding position profile."@en ;
  sth:xmlTag "positionProfileReference" ;
.
inq:proportional
  rdf:type owl:ObjectProperty ;
  rdfs:domain inq:AmountExtended ;
  rdfs:label "proportional"@en ;
  rdfs:range inq:Proportional ;
  skos:definition "The proportional element is used to specify whether certain work-related conditions such as leave entitlements, remuneration, or similar employment provisions are applied proportionally based on specific employee characteristics."@en ;
  sth:xmlTag "proportional" ;
.
inq:relationType
  rdf:type owl:DatatypeProperty ;
  rdfs:label "relation type"@en ;
  rdfs:range xsd:string ;
  sth:xmlTag "relationType" ;
.
inq:reference
  rdf:type owl:ObjectProperty ;
  rdfs:label "reference"@en ;
  rdfs:range inq:AllowanceReferenceExtended ;
  skos:definition "This element is used indicate relations to other elements of this structure. An example of such a relation could be that an allowance is used to calculate another allowance on a compounding basis. Meaning that the the value of allowance A is calculated before and used in the calculation of the value of allowance B."@en ;
  sth:xmlTag "reference" ;
.
inq:referenceDate
  rdf:type owl:ObjectProperty ;
  rdfs:label "reference date"@en ;
  rdfs:range setu:Occurrence ;
  skos:definition "The reference date specifies the date at which a base (grondslag) is evaluated, determining which rules, values, or conditions apply at that moment in time."@en ;
  sth:xmlTag "referenceDate" ;
.
inq:remuneration
  rdf:type owl:ObjectProperty ;
  rdfs:label "remuneration"@en ;
  rdfs:range inq:RemunerationPackage ;
  skos:definition "Details about the remuneration package, including salary tables based on the work duration. It includes one or more salary tables for a specific work duration or characteristics."@en ;
  sth:xmlTag "remuneration" ;
.
inq:remunerationIndicator
  rdf:type owl:DatatypeProperty ;
  rdfs:label "remuneration indicator"@en ;
  rdfs:range xsd:boolean ;
  skos:definition "This element can be used to indicate whether remuneration(s) is/are taken into consideration for calculating this base."@en ;
  sth:xmlTag "remunerationIndicator" ;
.
inq:salaryScaleStructure
  rdf:type owl:ObjectProperty ;
  rdfs:label "salary scale"@en ;
  rdfs:range inq:SalaryScale ;
  skos:definition "Base salary of a job or of an employee including minimum and maximum salary and certain salary steps."@en ;
  sth:xmlTag "salaryScaleStructure" ;
.
inq:salaryStep
  rdf:type owl:ObjectProperty ;
  rdfs:label "salary step"@en ;
  rdfs:range inq:SalaryScaleStep;
  skos:definition "Specifies the steps within each salary scale, where each step has a name/label, a salary value, and possible conditions."@en ;
  sth:xmlTag "salaryStep" ;
.
inq:sickPayArrangement
  rdf:type owl:ObjectProperty ;
  rdfs:domain inq:InquiryPayEquity ;
  rdfs:label "sick pay"@en ;
  rdfs:range inq:SickPayArrangement ;
  skos:definition "This element refers to the method in which the employer continues to compensate an employee when the employee has fallen ill."@en ;
  sth:xmlTag "sickPayArrangement" ;
.
inq:startSalaryStep
  rdf:type owl:DatatypeProperty ;
  rdfs:label "start salary step"@en ;
  rdfs:range xsd:string ;
  skos:definition "A code or numeric value indicating the initial salary step assigned to the role or employee upon entry into the salary scale. It defines the starting point within the organization's structured salary progression."@en ;
  sth:xmlTag "startSalaryStep" ;
.
inq:supplementaryArrangement
  rdf:type owl:ObjectProperty ;
  rdfs:domain inq:InquiryPayEquity ;
  rdfs:label "supplementary arrangement"@en ;
  rdfs:range inq:SupplementaryArrangement ;
  skos:definition "A container that specifies the supplementary arrangement(s) (In Dutch: 'aanvullende regelingen')."@en ;
  sth:xmlTag "supplementaryArrangement" ;
.
inq:sustainableEmployabilityArrangement
  rdf:type owl:ObjectProperty ;
  rdfs:domain inq:InquiryPayEquity ;
  rdfs:label "sustainable employability"@en ;
  rdfs:range inq:SustainableEmployabilityArrangement ;
  skos:definition "Sustainable employability allows for the employer to add information regarding sustainable employability arrangement that the employer might have (e.g. study budget for the employee)."@en ;
  sth:xmlTag "sustainableEmployabilityArrangement" ;
.
inq:type
  rdf:type owl:DatatypeProperty ;
  rdfs:label "type"@en ;
  rdfs:range xsd:string ;
  skos:definition "The type of agreement."@en ;
  sth:allowedValue "CollectiveLabourAgreement" ;
  sth:allowedValue "CollectiveLabourAgreementExtended" ;
  sth:allowedValue "CustomLabourAgreement" ;
  sth:allowedValue "Unknown" ;  
  sth:xmlTag "type" ;
.
inq:typeCode
  rdf:type owl:DatatypeProperty ;
  rdfs:label "type code"@en ;
  sth:xmlTag "typeCode" ;
.
inq:valuePerWeek
  rdf:type owl:DatatypeProperty ;
  rdfs:label "value per week"@en ;
  rdfs:range xsd:decimal ;
  skos:definition "The equivalent number of hours per week, useful for calculations such as leave entitlement."@en ;
  sth:xmlTag "valuePerWeek" ;
.
inq:waitingDays
  rdf:type owl:ObjectProperty ;
  rdfs:label "waiting days"@en ;
  rdfs:range inq:WaitingDays ;
  skos:definition "The amount of waiting days (NL: wachtdagen) that the worker is subjected to before being eligible to receive sick pay."@en ;
  sth:xmlTag "waitingDays" ;
.
inq:workDuration
  rdf:type owl:ObjectProperty ;
  rdfs:label "work duration"@en ;
  rdfs:range inq:WorkDuration ;
  skos:definition "Specifies the default work duration."@en ;
  sth:xmlTag "workDuration" ;
.
sth:allowedValue
  rdf:type owl:AnnotationProperty ;
.
sth:codelist
  rdf:type owl:AnnotationProperty ;
.
sth:xmlIsAttribute
  rdf:type owl:AnnotationProperty ;
.
sth:xmlTag
  rdf:type owl:AnnotationProperty ;
.
setu:
  rdf:type owl:Ontology ;
  dc:contributor <https://www.linkedin.com/in/michielstornebrink/> ;
  dc:contributor <https://www.linkedin.com/in/linda-oosterheert-006b0a10/> ;
  dc:creator <https://www.linkedin.com/in/jelte-bootsma-184634193/> ;
  dc:creator <https://www.linkedin.com/in/robin-de-veer/> ;
  dc:creator <https://www.linkedin.com/in/jeanine-de-graaf-beekhuis-7a9a4a151/> ;
  dc:description "The SETU ontology includes concepts created from the SETU context used in the SETU Standard for Planning and Scheduling and the version 2.x series of the Purchase to Pay standards."@en ;
  dc:modified "2026-03-02"^^xsd:date ;
  dc:title "SETU ontology" ;
  owl:versionInfo "2.9" ;
.
setu:AssignedWorker
  rdf:type owl:Class ;
  rdfs:subClassOf hropen:Worker ;
  rdfs:label "Assigned worker"@en ;
.
setu:AvailabilityLine
  rdf:type owl:Class ;
  rdfs:type "Availability line"@en ;
.
setu:Breaks
  rdf:type owl:Class ;
  rdfs:label "Breaks"@en ;
.
setu:BreakTrigger
  rdf:type owl:Class ;
  rdfs:label "Break trigger"@en ;
.
setu:ContactPerson
  rdf:type owl:Class ;
  rdfs:subClassOf hropen:SpecifiedPerson ;
  rdfs:label "Contact person"@en ;
.
setu:CollectiveLabourAgreement
  rdf:type owl:Class ;
  rdfs:label "Collective labour agreement"@en ;
  skos:definition "The collective labour agreement (CLA; CAO in Dutch) that determines the renumeration. In the Netherlands this can be the CLA of the ABU, NBBU or a specific CLA of the staffing customer."@en ;
.
setu:DatePeriod
  rdf:type owl:Class ;
  rdfs:label "Date period"@en ;
.
setu:EffectivePeriod
  rdf:type owl:Class ;
  rdfs:label "Effective period"@en ;
  skos:definition "A date period in which an associated object is effective."@en ;
.
setu:Id
  rdf:type owl:Class ;
  rdfs:label "Id"@en ;
.
setu:IdValue
  rdf:type rdfs:Datatype ;
  rdfs:label "Id value" ;
  rdfs:subClassOf xsd:string ;
  owl:onDatatype xsd:string ;
.
setu:Occurrence
  rdf:type owl:Class ;
  rdfs:label "Occurrence"@en ;
  skos:definition "Base type for occurrences with different occurrence types."@en ;
.
setu:OnCallContract
  rdf:type owl:Class ;
  rdfs:label "On call contract"@en ;
.
setu:Party
  rdf:type owl:Class ;
  rdfs:label "Party"@en ;
.
setu:Period
  rdf:type owl:Class ;
  rdfs:label "Period"@en ;
.
setu:PeriodicAvailabilityLine
  rdf:type owl:Class ;
  rdfs:subClassOf setu:AvailabilityLine ;
  rdfs:label "Periodic availability line"@en ;
.
setu:PeriodicPlanningLine
  rdf:type owl:Class ;
  rdfs:label "Periodic planning line"@en ;
  rdfs:subClassOf setu:PlanningLine ;
.
setu:Planning
  rdf:type owl:Class ;
  rdfs:label "Planning"@en ;
  rdfs:subClassOf hropen:Noun ;
.
setu:PlanningAssignment
  rdf:type owl:Class ;
  rdfs:label "Planning assignment"@en ;
  skos:definition "The Planning Assignment message is used to exchange the planning of a worker on a certain position. The message includes information about the position and the exact moments in time the worker is planned. The message is sent from the planning system at either the supplier or customer to the other party."@en ;
  rdfs:subClassOf setu:Planning ;
.
setu:PlanningConstraints
  rdf:type owl:Class ;
  rdfs:label "Planning constraints"@en ;
  skos:definition "The Planning Constraints message is used for exchanging information on the constraints that need to be taken into account for the planning of an individual worker related to a specific assignment. The message includes information about the availability and other relevant requirements or preferences. The message is sent from the back-office system of the supplier to the planning system at either the customer or supplier."@en ;
  rdfs:subClassOf setu:Planning ;
.
setu:PlanningLine
  rdf:type owl:Class ;
  rdfs:label "Planning line"@en ;
.
setu:PlanningRequest
  rdf:type owl:Class ;
  rdfs:label "Planning request"@en ;
  rdfs:subClassOf setu:Planning ;
  skos:definition "The Planning Request message is used by the customer to request the planning of workers for a certain position. The message includes information about the position and the exact moments in time workers are requested. The message is sent from the customer to the planning system at the supplier."@en ;
.
setu:PositionTask
  rdf:type owl:Class ;
  rdfs:label "Position task"@en ;
.
setu:RelatedWorker
  rdf:type owl:Class ;
  rdfs:subClassOf hropen:Worker ;
  rdfs:label "Related worker"@en ;
.
setu:RequestedWorker
  rdf:type owl:Class ;
  rdfs:subClassOf hropen:Worker ;
  rdfs:label "Requested worker"@en ;
.
setu:RequestForQuotationDetails
  rdf:type owl:Class ;
  rdfs:label "Request for quotation details"@en ;
.
setu:SingleAvailabilityLine
  rdf:type owl:Class ;
  rdfs:label "Single availability line"@en ;
  rdfs:subClassOf setu:AvailabilityLine ;
.
setu:SinglePlanningLine
  rdf:type owl:Class ;
  rdfs:label "Single planning line"@en ;
  rdfs:subClassOf setu:PlanningLine ;
.
setu:StaffingOrder
  rdf:type owl:Class ;
  rdfs:label "Staffing order"@en ;
  rdfs:subClassOf hropen:Noun ;
  skos:definition "The Staffing Order message is used by a staffing customer to request and order (a) worker(s) for an open position."@en ;
.
setu:TimePeriod
  rdf:type owl:Class ;
  rdfs:label "Time period"@en ;
.
setu:UnitCode
  rdf:type rdfs:Datatype ;
  rdfs:label "Unit code" ;
  rdfs:subClassOf xsd:string ;
  owl:onDatatype xsd:string ;
.
setu:WeekdayCode
  rdf:type rdfs:Datatype ;
  rdfs:label "Weekday code" ;
  rdfs:subClassOf xsd:string ;
  owl:onDatatype xsd:string ;
.
setu:actionCode
  rdf:type owl:DatatypeProperty ;
  rdfs:label "action code"@en ;
  rdfs:range xsd:string ;
  skos:definition "Specification of how the supplier or the customer should process this document."@en ;
  sth:allowedValue "GET" ;
  sth:allowedValue "POST" ;
  sth:allowedValue "PUT" ;
  sth:allowedValue "DELETE" ;  
  sth:xmlTag "actionCode" ;
.
setu:allowance
  rdf:type owl:ObjectProperty ;
  rdfs:label "allowance"@en ;
  rdfs:range hropen:TimeCardItem ;
  skos:definition "Contains data on expenses (costs incurred) and/or allowances (additional allowances or bonuses to be given for the duration of the time interval represented) that is being reported on the timecard."@en ;
  sth:xmlTag "allowance" ;
.
setu:assignedPeriodicPlanningLine
  rdf:type owl:ObjectProperty ;
  rdfs:domain setu:PlanningAssignment ;
  rdfs:label "assigned periodic planning line"@en ;
  rdfs:range setu:PeriodicPlanningLine ;
  skos:definition "A container for specifying a periodic planning line."@en ;
  sth:xmlTag "periodicPlanningLine" ;
.
setu:assignedSinglePlanningLine
  rdf:type owl:ObjectProperty ;
  rdfs:domain setu:PlanningAssignment ;
  rdfs:label "assigned single planning line"@en ;
  rdfs:range setu:SinglePlanningLine ;
  skos:definition "A container for specifying a single planning line."@en ;
  sth:xmlTag "singlePlanningLine" ;
.
setu:assignedStatus
  rdf:type owl:DatatypeProperty ;
  rdfs:domain setu:AssignedWorker ;
  rdfs:label "assigned status"@en ;
  rdfs:range xsd:boolean ;
  skos:definition "Specifies whether a worker is assigned to the position (true) and the planning is exchanged, or that the worker is not yet assigned (false), but the planning is already set and exchanged. Default value is 'true'."@en ;
  sth:xmlTag "assignedStatus" ;
.
setu:assignedWorker
  rdf:type owl:ObjectProperty ;
  rdfs:label "assigned worker"@en ;
  rdfs:range setu:AssignedWorker ;
  skos:definition "Container to specify the assigned worker." ;
  sth:xmlTag "assignedWorker" ;
.
setu:attachment
  rdf:type owl:ObjectProperty ;
  rdfs:label "attachment"@en ;
  rdfs:range hropen:Attachment ;
  skos:definition "Embedded attachment data or URL to actual attachment." ;
  sth:xmlTag "attachment" ;
.
setu:availabilityComment
  rdf:type owl:DatatypeProperty ;
  rdfs:domain setu:AvailabilityLine ;
  rdfs:label "availability comment"@en ;
  rdfs:range xsd:string ;
  skos:definition "Extra information about the availability of the worker additional to the status, e.g. the reason why the worker is (not) available."@en ;
  sth:xmlTag "availabilityComment" ;
.
setu:availabilityLineId
  rdf:type owl:ObjectProperty ;
  rdfs:domain setu:AvailabilityLine ;
  rdfs:label "line id"@en ;
  rdfs:range setu:Id ;
  skos:definition "Provides a unique identifier of the availability line."@en ;
  skos:note "The line identifiers used for periodic and single availability lines must be unique for each Planning Constraints message and may not overlap. In other words, an identifier used for a periodic availability line must not be used as an identifier for a single availability line, and vice versa."@en ;
  sth:xmlTag "lineId" ;
.
setu:availabilityPeriod
  rdf:type owl:DatatypeProperty ;
  rdfs:domain setu:PeriodicAvailabilityLine ;
  rdfs:label "availability period"@en ;
  rdfs:range xsd:string ;
  skos:definition "The period to which the availability line applies."@en ;
  sth:allowedValue "Monday" ;
  sth:allowedValue "Tuesday" ;
  sth:allowedValue "Wednesday" ;
  sth:allowedValue "Thursday" ;
  sth:allowedValue "Friday" ;
  sth:allowedValue "Saturday" ;
  sth:allowedValue "Sunday" ;
  sth:allowedValue "Daily" ;
  sth:allowedValue "Weekly" ;
  sth:allowedValue "Monthly" ;
  sth:allowedValue "FourWeekly" ;
  sth:xmlTag "availabilityPeriod" ;
.
setu:availabilityStatus
  rdf:type owl:DatatypeProperty ;
  rdfs:domain setu:AvailabilityLine ;
  rdfs:label "availability status"@en ;
  rdfs:range xsd:string ;
  skos:definition "Indicates the availability status of an availability line by 'Available', 'NotAvailable', or 'RatherNot'."@en ;
  sth:allowedValue "Available" ;
  sth:allowedValue "NotAvailable" ;
  sth:allowedValue "RatherNot" ;
  sth:xmlTag "availabilityStatus" ;
.
setu:basedOn
  rdf:type owl:DatatypeProperty ;
  rdfs:domain setu:CollectiveLabourAgreement ;
  rdfs:label "based on"@en ;
  rdfs:range xsd:string ;
  skos:definition "A collective labour agreement (CLA) applies if the employer is a member of the industry association, if the CLA has been declared generally binding for the sector by the Minister of Social Affairs and Employment, or if it is declared applicable in the employee's employment contract."@en ;
  sth:xmlTag "basedOn" ;
.
setu:breakDuration
  rdf:type owl:DatatypeProperty ;
  rdfs:domain setu:BreakTrigger ;
  rdfs:label "break duration"@en ;
  rdfs:range xsd:time ;
  skos:definition "The duration of the break, expressed using time datatype."@en ;
  sth:xmlTag "breakDuration" ;
.
setu:breaks
  rdf:type owl:ObjectProperty ;
  rdfs:label "breaks"@en ;
  rdfs:range setu:Breaks ;
  skos:definition "Container specifying the break(s) the worker gets during the worked shift."@en ;
  sth:xmlTag "breaks" ;
.
setu:breakTrigger
  rdf:type owl:ObjectProperty ;
  rdfs:domain setu:Breaks ;
  rdfs:label "break trigger"@en ;
  rdfs:range setu:BreakTrigger ;
  skos:definition "Container to specify after how many working hours a break occurs and how long the break takes."@en ;
  sth:xmlTag "breakTrigger" ;
.
setu:buildingAddition
  rdf:type owl:DatatypeProperty ;
  rdfs:label "building addition"@en ;
  rdfs:range xsd:string ;
  skos:definition "Any additional, identifiable information regarding the building, e.g. the floor, room, apartment number within a building."@en ;
  sth:xmlTag "buildingAddition" ;
.
setu:collectiveLabourAgreement
  rdf:type owl:ObjectProperty ;
  rdfs:label "collective labour agreement"@en ;
  rdfs:range setu:CollectiveLabourAgreement ;
  skos:definition "Information about the collective labour agreement (CLA; CAO in Dutch) that determines the renumeration. In the Netherlands this can be the CLA of the ABU, NBBU or a specific CLA of the staffing customer."@en ;
  sth:xmlTag "collectiveLabourAgreement" ;
.
setu:comments 
  rdf:type owl:DatatypeProperty ;
  rdfs:label "comments"@en ;
  rdfs:range xsd:string ;
  skos:definition "Additional comments about the message."@en ;
  sth:xmlTag "comments" ;
.
setu:contractWorkingPeriods
  rdf:type owl:ObjectProperty ;
  rdfs:label "contract working periods"@en ;
  rdfs:range hropen:WorkingPeriod ;
  skos:definition "A container for specifying the number of hours for a worker agreed on in the contract (in Dutch: overeengekomen arbeidsomvang)."@en ;
  sth:xmlTag "contractWorkingPeriods" ;
.
setu:customer
  rdf:type owl:ObjectProperty ;
  rdfs:label "customer"@en ;
  sth:xmlTag "customer" ;
.
setu:customerSpecificRequirements
  rdf:type owl:ObjectProperty ;
  rdfs:label "customer specific requirements"@en ;
  rdfs:range xsd:any ;
  skos:definition "Container for customer specific requirements. This container can only be filled with customer specific requirements that have been permitted and added to the customer specific requirements codelist by the SETU."@en ;
  sth:xmlTag "customerSpecificRequirements" ;
.
setu:customLabourAgreement
  rdf:type owl:DatatypeProperty ;
  rdfs:label "custom labour agreement"@en ;
  rdfs:range xsd:boolean ;
  skos:definition "Indicator to determine whether a custom labour agreement is active."@en ;
  sth:xmlTag "customLabourAgreement" ;
.
setu:datePeriod
  rdf:type owl:ObjectProperty ;
  rdfs:domain setu:Period ;
  rdfs:label "date period"@en ;
  rdfs:range setu:DatePeriod ;
  sth:xmlTag "datePeriod" ;
.
setu:dayAssignment
  rdf:type owl:DatatypeProperty ;
  rdfs:label "day assignment"@en ;
  rdfs:range xsd:date ;
  skos:definition "Specification of the administrative start date of the time card item. This is useful in case of nightshifts where the start and end date of a time interval are not the same."@en ;
  sth:xmlTag "dayAssignment" ;
.
setu:description
  rdf:type owl:DatatypeProperty ;
  rdfs:label "description"@en ;
  rdfs:range xsd:string ;
  sth:xmlTag "description" ;
.
setu:effectivePeriod
  rdf:type owl:ObjectProperty ;
  rdfs:label "effective period"@en ;
  rdfs:range setu:EffectivePeriod ;
  sth:xmlTag "effectivePeriod" ;
.
setu:effectiveTimePeriod
  rdf:type owl:ObjectProperty ;
  rdfs:label "effective time period"@en ;
  rdfs:range hropen:EffectiveTimePeriod ;
  sth:xmlTag "effectiveTimePeriod" ;
.
setu:employeeContract
  rdf:type owl:DatatypeProperty ;
  rdfs:label "employee contract"@en ;
  rdfs:range xsd:boolean ;
  skos:definition "Determines whether or not the worker has a contract at the staffing supplier."@en ;
  sth:xmlTag "employeeContract" ;
.
setu:employeePhase
  rdf:type owl:DatatypeProperty ;
  rdfs:label "employee phase"@en ;
  rdfs:range xsd:string;
  skos:definition "Determines the employment phase in which the worker is in according to either the ABU CLA or the NBBU CLA."@en ;
  sth:xmlTag "employeePhase" ;
.
setu:endDate
  rdf:type owl:DatatypeProperty ;
  rdfs:label "end date"@en ;
  rdfs:range xsd:date ;
  skos:definition "The end date is the end of a stay, an episode, or other period of time."@en ;
  sth:xmlTag "endDate" ;
.
setu:endDateTime
  rdf:type owl:DatatypeProperty ;
  rdfs:label "end date time"@en ;
  rdfs:range xsd:dateTime ;
  skos:definition "The end date and end time is the end of a stay, an episode, or other period of time."@en ;
  sth:xmlTag "endDateTime" ;
.
setu:endTime
  rdf:type owl:DatatypeProperty ;
  rdfs:label "end time"@en ;
  rdfs:range xsd:time ;
  skos:definition "End time is the end, expressed in time, of an period of time."@en ;
  sth:xmlTag "endTime" ;
.
setu:establishment
  rdf:type owl:ObjectProperty ;
  rdfs:domain hropen:Party ;
  rdfs:label "establishment"@en ;
  rdfs:range hropen:EmployerEstablishment ;
  skos:definition "Information to identify and reference a specific establishment within an organization."@en ;
  sth:xmlTag "establishment" ;
.
setu:homeOfficeIndicator
  rdf:type owl:DatatypeProperty ;
  rdfs:label "home office indicator"@en ;
  rdfs:range xsd:string ;
  skos:definition "Contains the value 'Home' or 'Office' to indicate for a timecard item whether the work was executed at home or at the office."@en ;
  sth:allowedValue "Home" ;
  sth:allowedValue "Office" ;
  sth:xmlTag "homeOfficeIndicator" ;
.
setu:hours
  rdf:type owl:DatatypeProperty ;
  rdfs:label "hours"@en ;
  rdfs:range xsd:decimal ;
  skos:definition "The amount of hours expressed in decimals."@en ;
  sth:xmlTag "hours" ;
.
setu:houseNumber
  rdf:type owl:DatatypeProperty ;
  rdfs:label "house number"@en ;
  rdfs:range xsd:string ;
  skos:definition "The house number of the address."@en ;
  sth:xmlTag "houseNumber" ;
.
setu:houseNumberAddition
  rdf:type owl:DatatypeProperty ;
  rdfs:label "house number addition"@en ;
  rdfs:range xsd:string ;
  skos:definition "The addition of the house number."@en ;
  sth:xmlTag "houseNumberAddition" ;
.
setu:indicator
  rdf:type owl:DatatypeProperty ;
  rdfs:label "indicator"@en ;
  rdfs:range xsd:boolean ;
  sth:xmlTag "indicator" ;
.
setu:industryIdentifier
  rdf:type owl:ObjectProperty ;
  rdfs:label "industry identifier"@en ;
  rdfs:range hropen:Identifier ;
  skos:definition "The types of industry to which the organization belongs. The industry identifiers could be referenced to using a standard taxonomy, such as the CBS - SBI 2008 (Standaard Bedrijfsindeling)."@en ;
  sth:xmlTag "industryIdentifier" ;
.
setu:insuranceGroup
  rdf:type owl:DatatypeProperty ;
  rdfs:label "insurance group"@en ;
  rdfs:range xsd:string ;
  skos:definition "Determines the insurance group the worker is part of."@en ;
  sth:xmlTag "insuranceGroup" ;
.
setu:licenses
  rdf:type owl:ObjectProperty ;
  rdfs:domain hropen:PositionQualification ;
  rdfs:label "licenses"@en ;
  rdfs:range hropen:License ;
  skos:definition "The required licenses for the position."@en ;
  sth:xmlTag "licenses" ;
.
setu:lineId
  rdf:type owl:ObjectProperty ;
  rdfs:label "line id"@en ;
  rdfs:range setu:Id ;
  skos:definition "The unique identifier of this specific line."@en ;
  sth:xmlTag "lineId" ;
.
setu:maximumTravelDistance
  rdf:type owl:DatatypeProperty ;
  rdfs:label "maximum travel distance"@en ;
  rdfs:range xsd:decimal ;
  skos:definition "The maximum number of kilometers the worker is willing to travel."@en ;
  sth:xmlTag "maximumTravelDistance" ;
.
setu:multiplier
  rdf:type owl:DatatypeProperty ;
  rdfs:label "multiplier"@en ;
  rdfs:range xsd:decimal ;
  skos:definition "The multiplier that should be applied to the pay rate in order to determine the real amount that has to be paid or billed (depending on toBeBilled and toBePaid). The 'standard multiplier' for a pay rate without mark-up is 100% (fill in value '100'). A different value can be used in situations where a mark-up is provided on top of the standard rate. The mark-up should be added to the 'base percentage' of 100%, so a mark-up of 50% (1.5 times the standard rate) makes a multiplier of 150%."@en ;
  sth:xmlTag "multiplier" ;
.
setu:multiVendorDistribution
  rdf:type owl:DatatypeProperty ;
  rdfs:domain setu:RequestForQuotationDetails ;
  rdfs:label "multi vendor distribution"@en ;
  rdfs:range xsd:boolean ;
  skos:definition "Indication whether the staffing position is sent to multiple staffing suppliers ('true') or not ('false')."@en ;
  sth:xmlTag "multiVendorDistribution" ;
.
setu:name
  rdf:type owl:DatatypeProperty ;
  rdfs:label "name"@en ;
  rdfs:range xsd:string ;
  sth:xmlTag "name" ;
.
setu:onCallContract
  rdf:type owl:ObjectProperty ;
  rdfs:domain setu:AssignedWorker ;
  rdfs:label "on call contract"@en ;
  rdfs:range setu:OnCallContract ;
  skos:definition "Container specifying the an on-call contract the worker has at the staffing supplier."@en ;
  sth:xmlTag "onCallContract" ;
.
setu:onCallIndicator
  rdf:type owl:DatatypeProperty ;
  rdfs:domain setu:OnCallContract ;
  rdfs:label "on call indicator"@en ;
  rdfs:range xsd:boolean ;
  skos:definition "Indicates whether the contract the worker has at the staffing supplier is a on-call contract (true) or not (false)."@en ;
  sth:xmlTag "onCallIndicator" ;
.
setu:orderType
  rdf:type owl:DatatypeProperty ;
  rdfs:domain setu:StaffingOrder ;
  rdfs:label "order type"@en ;
  rdfs:range xsd:string ;
  skos:definition "Specifies whether the Staffing Order message is used as RFQ (= request for quotation) or Order (= procurement order)."@en ;
  sth:allowedValue "RFQ" ;
  sth:allowedValue "Order" ;
  sth:xmlTag "orderType" ;
.
setu:paidOrUnpaid
  rdf:type owl:DatatypeProperty ;
  rdfs:domain setu:Breaks ;
  rdfs:label "paid or unpaid"@en ;
  rdfs:range xsd:string ;
  skos:definition "Indication whether the break is 'Paid' or 'Unpaid'."@en ;
  sth:allowedValue "Paid" ;
  sth:allowedValue "Unpaid" ;
  sth:xmlTag "paidOrUnpaid" ;
.
setu:payRates
  rdf:type owl:ObjectProperty ;
  rdfs:label "pay rates"@en ;
  rdfs:range hropen:PayRate ;
  sth:xmlTag "payRates" ;
.
setu:period
  rdf:type owl:ObjectProperty ;
  rdfs:label "period"@en ;
  sth:xmlTag "period" ;
.
setu:periodicAvailabilityLine
  rdf:type owl:ObjectProperty ;
  rdfs:domain setu:PlanningConstraints ;
  rdfs:label "periodic availability line"@en ;
  rdfs:range setu:PeriodicAvailabilityLine ;
  skos:definition "The periodic availability line of a worker containing the preferred working days and times."@en ;
  sth:xmlTag "periodicAvailabilityLine" ;
.
setu:periodicAvailabilityLineReference
  rdf:type owl:ObjectProperty ;
  rdfs:domain setu:SingleAvailabilityLine ;
  rdfs:label "periodic availability line reference"@en ;
  rdfs:range setu:PeriodicAvailabilityLine ;
  skos:definition "Reference to the periodic availability line related with this single availability line."@en ;
  sth:xmlTag "periodicAvailabilityLineReference" ;
.
setu:periodicPlanningLineReference
  rdf:type owl:ObjectProperty ;
  rdfs:domain setu:SinglePlanningLine ;
  rdfs:label "periodic planning line reference"@en ;
  rdfs:range setu:PeriodicPlanningLine ;
  skos:definition "Reference to the periodic planning line related with this single planning line."@en ;
  sth:xmlTag "periodicPlanningLineReference" ;
.
setu:planningLineId
  rdf:type owl:ObjectProperty ;
  rdfs:domain setu:PlanningLine ;
  rdfs:label "planning line id"@en ;
  rdfs:range setu:Id ;
  skos:definition "Provides a unique identifier of the planning line."@en ;
  skos:note "The line identifiers used for periodic and single planning lines must be unique for each Planning Request/Assignment message and may not overlap. In other words, an identifier used for a periodic planning line must not be used as an identifier for a single planning line, and vice versa."@en ;
  sth:xmlTag "lineId" ;
.
setu:planningLineName
  rdf:type owl:DatatypeProperty ;
  rdfs:domain setu:PlanningLine ;
  rdfs:label "planning line name"@en ;
  rdfs:range xsd:string ;
  skos:definition "The name of the planning line, i.e. a small summary of the planning line."@en ;
  sth:xmlTag "planningLineName" ;
.
setu:planningPeriod
  rdf:type owl:DatatypeProperty ;
  rdfs:domain setu:PeriodicPlanningLine ;
  rdfs:label "planning period"@en ;
  rdfs:range xsd:string ;
  skos:definition "The period, one day in a week, to which the planning line applies."@en ;
  sth:allowedValue "Monday" ;
  sth:allowedValue "Tuesday" ;
  sth:allowedValue "Wednesday" ;
  sth:allowedValue "Thursday" ;
  sth:allowedValue "Friday" ;
  sth:allowedValue "Saturday" ;
  sth:allowedValue "Sunday" ;
  sth:xmlTag "planningPeriod" ;
.
setu:planningRequestReference
  rdf:type owl:ObjectProperty ;
  rdfs:domain setu:PlanningAssignment ;
  rdfs:label "planning request reference"@en ;
  rdfs:range setu:PlanningRequest ;
  skos:definition "Reference to the related planning request."@en ;
  sth:xmlTag "planningRequestReference" ;
.
setu:positionProfile
  rdf:type owl:ObjectProperty ;
  rdfs:label "position profile"@en ;
  rdfs:range hropen:PositionProfile ;
  sth:xmlTag "positionProfile" ;
.
setu:positionReason
  rdf:type owl:DatatypeProperty ;
  rdfs:domain hropen:PositionProfile ;
  rdfs:label "position reason"@en ;
  rdfs:range xsd:string;
  skos:definition "The reason for the open position."@en ;
  sth:xmlTag "positionReason" ;
.
setu:positionTask
  rdf:type owl:ObjectProperty ;
  rdfs:domain hropen:PositionProfile ;
  rdfs:label "position task"@en ;
  rdfs:range setu:PositionTask;
  skos:definition "The type of task or activity the worker performs on the position."@en ;
  sth:xmlTag "positionTask" ;
.
setu:primaryLocation
  rdf:type owl:DatatypeProperty ;
  rdfs:label "primary location"@en ;
  rdfs:range xsd:boolean;
  skos:definition "Indicates whether the location is the primary work location (Dutch: standplaats) of the position."@en ;
  sth:xmlTag "primaryLocation" ;
.
setu:purchaseOrderLineItem
  rdf:type owl:DatatypeProperty ;
  rdfs:label "purchase order line item"@en ;
  rdfs:range xsd:string;
  sth:xmlTag "purchaseOrderLineItem" ;
.
setu:quantity
  rdf:type owl:ObjectProperty ;
  rdfs:label "quantity"@en ;
  rdfs:range hropen:Quantity;
  sth:xmlTag "quantity" ;
.
setu:rateType
  rdf:type owl:DatatypeProperty ;
  rdfs:label "rate type"@en ;
  rdfs:range xsd:string ;
  skos:definition "Indicates whether the rate applies to a time interval, an allowance or an expense."@en ;
  sth:allowedValue "TimeInterval" ;
  sth:allowedValue "Allowance/Expense" ;
  sth:xmlTag "rateType" ;
.
setu:recruitedBy
  rdf:type owl:DatatypeProperty ;
  rdfs:label "recruited by"@en ;
  rdfs:range xsd:string ;
  sth:allowedValue "Supplier" ;
  sth:allowedValue "Customer" ;
  skos:definition "Determines whether the staffing customer or staffing supplier has recruited the worker."@en ;
  sth:xmlTag "recruitedBy" ;
.
setu:referenceTitle
  rdf:type owl:DatatypeProperty ;
  rdfs:domain hropen:PositionProfile ;
  rdfs:label "reference title"@en ;
  rdfs:range xsd:string ;
  skos:definition "This reference title provides a reference to the function/role as defined within the Collective Labour Agreement (CAO)."@en ;
  skos:note "If a collective labour agreement (CLA) applies and includes a job classification framework, the reference titles from that framework must be specified in the position profiles."@en ;
  sth:xmlTag "referenceTitle" ;
.
setu:relatedWorker
  rdf:type owl:ObjectProperty ;
  rdfs:label "related worker"@en ;
  rdfs:range setu:RelatedWorker ;
  skos:note "E.g. workers travel together towards their working location and therefore need to planned on the same working hours, etc."@en ;
  sth:xmlTag "relatedWorker" ;
.
setu:relatedWorkerType
  rdf:type owl:DatatypeProperty ;
  rdfs:domain setu:RelatedWorker ;
  rdfs:label "related worker type"@en ;
  rdfs:range xsd:string ;
  skos:definition "Identifies the relation type between the worker and the related worker as 'Preferred' or 'Required'."@en ;
  sth:allowedValue "Preferred" ;
  sth:allowedValue "Required" ;
  sth:xmlTag "relatedWorkerType" ;
.
setu:requestComments
  rdf:type owl:DatatypeProperty ;
  rdfs:domain setu:PlanningRequest ;
  rdfs:label "request comments"@en ;
  rdfs:range xsd:string ;
  skos:definition "Additional comments about the planning request."@en ;
  sth:xmlTag "requestComments" ;
.
setu:requestedPeriodicPlanningLine
  rdf:type owl:ObjectProperty ;
  rdfs:domain setu:PlanningRequest ;
  rdfs:label "requested periodic planning line"@en ;
  rdfs:range setu:PeriodicPlanningLine ;
  skos:definition "A container for specifying a periodic planning line."@en ;
  sth:xmlTag "periodicPlanningLine" ;
.
setu:requestForQuotationDetails
  rdf:type owl:ObjectProperty ;
  rdfs:domain setu:StaffingOrder ;
  rdfs:label "request for quotation details"@en ;
  rdfs:range setu:RequestForQuotationDetails ;
  skos:definition "Contains elements only used when the Staffing Order message is used as request for quotation. The elements are used to specify further details regarding the handling of the request for quotation and the quotation (Human Resource message) itself."@en ;
  sth:xmlTag "requestForQuotationDetails" ;
.
setu:resourceClassificationInclusion
  rdf:type owl:ObjectProperty ;
  rdfs:label "resource classification inclusion"@en ;
  rdfs:range hropen:ResourceClassificationInclusion ;
  skos:definition "Holds customer specific properties of an entity."@en ;
  sth:xmlTag "resourceClassificationInclusion" ;
.
setu:positionQuantity
  rdf:type owl:DatatypeProperty ;
  rdfs:domain setu:PlanningLine ;
  rdfs:label "position quantity"@en ;
  rdfs:range xsd:integer ;
  skos:definition "The number of workers requested for this specific period of the staffing position."@en ;
  sth:xmlTag "positionQuantity" ;
.
setu:reasonOfChange
  rdf:type owl:DatatypeProperty ;
  rdfs:label "reason of change"@en ;
  rdfs:range xsd:string ;
  skos:definition "The reason for the change of the (status of the) message."@en ;
  sth:xmlTag "reasonOfChange" ;
.
setu:requestedSinglePlanningLine
  rdf:type owl:ObjectProperty ;
  rdfs:domain setu:PlanningRequest ;
  rdfs:label "requested single planning line"@en ;
  rdfs:range setu:SinglePlanningLine ;
  skos:definition "A container for specifing a single planning line."@en ;
  sth:xmlTag "singlePlanningLine" ;
.
setu:residenceAddress
  rdf:type owl:ObjectProperty ;
  rdfs:domain hropen:CandidatePerson ;
  rdfs:label "residence address"@en ;
  rdfs:range hropen:AddressTypeArray ;
  skos:definition "Container for specifying the residence address. Only use this container if the residence address differs from the postal address."@en ;
  sth:xmlTag "residenceAddress" ;
.
setu:requestedWorker
  rdf:type owl:ObjectProperty ;
  rdfs:domain hropen:PositionProfile ;
  rdfs:label "requested worker"@en ;
  rdfs:range setu:RequestedWorker ;
  skos:definition "Container to specify the preferred worker(s)."@en ;
  sth:xmlTag "requestedWorker" ;
.
setu:salaryScale
  rdf:type owl:DatatypeProperty ;
  rdfs:label "salary scale"@en ;
  rdfs:range xsd:string;
  skos:definition "Specifies the salary scale (and step within that scale) the worker will have at the staffing customer."@en ;
  sth:xmlTag "salaryScale" ;
.
setu:schemeAgencyId
  rdf:type owl:DatatypeProperty ;
  rdfs:domain setu:Id ;
  rdfs:label "scheme agency id"@en ;
  rdfs:range xsd:string ;
  skos:definition "The organization that issues the identifier. This organization is also responsible for unicity of the identifier within its own context."@en ;
  sth:allowedValue "Customer" ;
  sth:allowedValue "Supplier" ;
  sth:xmlTag "schemeAgencyId" ;
.
setu:singleAvailabilityLine
  rdf:type owl:ObjectProperty ;
  rdfs:domain setu:PlanningConstraints ;
  rdfs:label "single availability line"@en ;
  rdfs:range setu:SingleAvailabilityLine ;
  skos:definition "Container to specify a single availability line of a worker containing the preferred working days and times. This includes exceptions to the periodic availability, or occasional availability as addition to the periodic availability."@en ;
  sth:xmlTag "singleAvailabilityLine" ;
.
setu:singleAvailabilityType
  rdf:type owl:DatatypeProperty ;
  rdfs:domain setu:SingleAvailabilityLine ;
  rdfs:label "single availability type"@en ;
  rdfs:range xsd:string ;
  skos:definition "Specifies whether a single availability line is an exception on a periodic availability line or a new occasional single availability line."@en ;
  skos:note """- Exception: Use 'Exception' and provide a unique identifier to add a single availability line. Furthermore, provide the identifier of the periodic availability line it relates to. The single availability line will function as an exception to the periodic availability line.
  - Occasional: Use 'Occasional' and provide a new, unique identifier to add a single availability line. An occasional single availability type refers to a specific availability line that does not occur often."""@en ;
  sth:allowedValue "Exception" ;
  sth:allowedValue "Occasional" ;
  sth:xmlTag "singleAvailabilityType" ;
.
setu:singlePlanningType
  rdf:type owl:DatatypeProperty ;
  rdfs:domain setu:SinglePlanningLine ;
  rdfs:label "single planning type"@en ;
  rdfs:range xsd:string ;
  skos:definition "Specifies whether a single planning line is an exception on a periodic planning line or a new occasional single planning line."@en ;
  skos:note """- Exception: Use 'Exception' and provide a unique identifier to add a single planning line. Furthermore, provide the identifier of the periodic planning line it relates to. The single planning line will function as an exception to the periodic planning line.
  - Occasional: Use 'Occasional' and provide a new, unique identifier to add a single planning line. An occasional single planning type refers to a specific planning line that does not occur often."""@en ;
  sth:allowedValue "Exception" ;
  sth:allowedValue "Occasional" ;
  sth:xmlTag "singlePlanningType" ;
.
setu:staffingIds
  rdf:type owl:ObjectProperty ;
  rdfs:label "staffing ids"@en ;
  rdfs:range hropen:StaffingReferenceIds ;
  skos:definition "A collection of identifiers related to this message."@en ;
  sth:xmlTag "staffingIds" ;
.
setu:standByIndicator
  rdf:type owl:DatatypeProperty ;
  rdfs:domain hropen:PositionProfile ;
  rdfs:label "stand by indicator"@en ;
  rdfs:range xsd:boolean ;
  skos:definition "Specifies whether the position is a stand-by (Dutch: reserve) position (true) or a regular position (false). Default value is 'false'. This element is not used to specify an on-call worker (Dutch: oproepkracht)."@en ;
  sth:xmlTag "standByIndicator" ;
.
setu:startDate
  rdf:type owl:DatatypeProperty ;
  rdfs:label "start date"@en ;
  rdfs:range xsd:date ;
  skos:definition "The start date is the start of a stay, an episode, or other period of time."@en ;
  sth:xmlTag "startDate" ;
.
setu:startDateTime
  rdf:type owl:DatatypeProperty ;
  rdfs:label "start date time"@en ;
  rdfs:range xsd:dateTime ;
  skos:definition "The start date and time is the start of a stay, an episode, or other period of time."@en ;
  sth:xmlTag "startDateTime" ;
.
setu:startTime
  rdf:type owl:DatatypeProperty ;
  rdfs:label "start time"@en ;
  rdfs:range xsd:time ;
  skos:definition "The start time of a period of time."@en ;
  sth:xmlTag "startTime" ;
.
setu:streetName
  rdf:type owl:DatatypeProperty ;
  rdfs:label "street name"@en ;
  rdfs:range xsd:string ;
  skos:definition "The street name of the address."@en ;
  sth:xmlTag "streetName" ;
.
setu:supplier
  rdf:type owl:ObjectProperty ;
  rdfs:label "supplier"@en ;
  rdfs:range hropen:Party ;
  sth:xmlTag "supplier" ;
.
setu:toBeBilled
  rdf:type owl:DatatypeProperty ;
  rdfs:label "to be billed"@en ;
  rdfs:range xsd:boolean ;
  skos:definition "Specifies whether this pay rate is specified for billing purposes or not."@en ;
  sth:xmlTag "toBeBilled" ;
.
setu:toBePaid
  rdf:type owl:DatatypeProperty ;
  rdfs:label "to be paid"@en ;
  rdfs:range xsd:boolean ;
  skos:definition "Specifies whether this pay rate is specified for payment purposes or not."@en ;
  sth:xmlTag "toBePaid" ;
.
setu:timePeriod
  rdf:type owl:ObjectProperty ;
  rdfs:domain setu:Period ;
  rdfs:label "time period"@en ;
  rdfs:range setu:TimePeriod ;
  sth:xmlTag "timePeriod" ;
.
setu:travelDistance
  rdf:type owl:DatatypeProperty ;
  rdfs:domain hropen:PositionProfile ;
  rdfs:label "travel distance"@en ;
  rdfs:range xsd:decimal ;
  skos:definition "Specifies the number of kilometers between the home of the worker and the primary work location (Dutch: standplaats)."@en ;
  sth:xmlTag "travelDistance" ;
.
setu:unitCode
  rdf:type owl:DatatypeProperty ;
  rdfs:label "unit code"@en ;
  skos:definition "The unit of measure."@en ;
  sth:xmlTag "unitCode" ;
.
setu:vacationWorker
  rdf:type owl:DatatypeProperty ;
  rdfs:label "vacation worker"@en ;
  rdfs:range xsd:boolean ;
  skos:definition "Determines whether the worker is a vacation worker or not."@en ;
  sth:xmlTag "vacationWorker" ;
.
setu:value
  rdf:type owl:DatatypeProperty ;
  rdfs:domain setu:Id ;
  rdfs:label "value"@en ;
  rdfs:range setu:IdValue ;
  skos:definition "The value of the unique identifier."@en ;
  sth:xmlTag "value" ;
.
setu:weekday
  rdf:type owl:DatatypeProperty ;
  rdfs:label "weekday"@en ;
  rdfs:range setu:WeekdayCode ;
  sth:xmlTag "weekday" ;
.
setu:workDescription
  rdf:type owl:DatatypeProperty ;
  rdfs:domain hropen:PositionProfile ;
  rdfs:label "work description"@en ;
  rdfs:range xsd:string ;
  skos:definition "The free text description of the work that this position normally requires."@en ;
  sth:xmlTag "workDescription" ;
.
setu:worker
  rdf:type owl:ObjectProperty ;
  rdfs:domain setu:PlanningConstraints ;
  rdfs:label "worker"@en ;
  rdfs:range hropen:Worker ;
  skos:definition "Worker is a Person Role and is defined as someone who performs labor for an organization. Worker is an abstraction for other more specific work-related roles, for example, Employee and Contractor. (ADP)"@en ;
  sth:xmlTag "worker" ;
.
setu:workingPeriods
  rdf:type owl:ObjectProperty ;
  rdfs:label "working periods"@en ;
  rdfs:range hropen:WorkingPeriod ;
  skos:definition "Describes the working period of the position that the worker is required for, e.g. 32 hours per week and/or 4 days per week. This is excluding break time(s)."@en ;
  sth:xmlTag "workingPeriods" ;
.